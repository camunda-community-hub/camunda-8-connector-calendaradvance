{
  "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "name": "Calendar advance function",
  "id": "io.camunda.connector.calendaradvance.CalendarAdvanceFunction",
  "description": "Advance a date in calendar in time or day, using duration and business calendar, holidays: Advance the calendar by days. Advance my be forward or backward,Advance in the Calendar based on hours time.",
  "documentationRef": "https://docs.camunda.io/docs/components/modeler/web-modeler/connectors/available-connectors/template/",
  "icon": {
    "contents": "data:image/png;base64,\u003d\u003d"
  },
  "category": {
    "id": "connectors",
    "name": "Connectors"
  },
  "appliesTo": [
    "bpmn:ServiceTask"
  ],
  "elementType": {
    "value": "bpmn:ServiceTask"
  },
  "groups": [
    {
      "id": "Input",
      "label": "Input"
    },
    {
      "id": "Output",
      "label": "Output"
    }
  ],
  "properties": [
    {
      "binding": {
        "type": "zeebe:taskDefinition:type"
      },
      "type": "Hidden",
      "value": "c-calendaradvance-function"
    },
    {
      "binding": {
        "key": "resultVariable",
        "type": "zeebe:taskHeader"
      },
      "type": "Hidden",
      "value": "result"
    },
    {
      "id": "calendarAdvanceFunction",
      "label": "CalendarAdvance Function",
      "description": "Choose the function to execute",
      "type": "Dropdown",
      "choices": [
        {
          "name": "Advance days",
          "value": "advance-day"
        },
        {
          "name": "Advance hours",
          "value": "advance-hours"
        }
      ],
      "binding": {
        "name": "calendarAdvanceFunction",
        "type": "zeebe:input"
      },
      "constraints": {
        "notEmpty": true
      },
      "group": "Input"
    },
    {
      "id": "direction",
      "label": "Direction",
      "description": "Direction to advance",
      "type": "Dropdown",
      "choices": [
        {
          "name": "forward",
          "value": "forward"
        },
        {
          "name": "backward",
          "value": "backward"
        }
      ],
      "binding": {
        "name": "direction",
        "type": "zeebe:input"
      },
      "constraints": {
        "notEmpty": true
      },
      "group": "Input"
    },
    {
      "condition": {
        "property": "calendarAdvanceFunction",
        "oneOf": [
          "advance-hours"
        ]
      },
      "id": "startDate",
      "label": "Start Date",
      "description": "Calculation sart with this date",
      "type": "String",
      "feel": "optional",
      "binding": {
        "name": "startDate",
        "type": "zeebe:input"
      },
      "constraints": {
        "notEmpty": true
      },
      "group": "Input"
    },
    {
      "condition": {
        "property": "calendarAdvanceFunction",
        "oneOf": [
          "advance-hours"
        ]
      },
      "id": "duration",
      "label": "Duration",
      "description": "Duration ISO 8601 : P2DT5H23M54S",
      "type": "String",
      "feel": "optional",
      "binding": {
        "name": "duration",
        "type": "zeebe:input"
      },
      "constraints": {
        "notEmpty": true
      },
      "group": "Input"
    },
    {
      "condition": {
        "property": "calendarAdvanceFunction",
        "oneOf": [
          "advance-hours"
        ]
      },
      "id": "businessCalendar_optional",
      "label": "Provide Business Calendar?",
      "description": "List of business calendar slot. Default is Monday to Friday, 09:00 to 18:00",
      "value": "false",
      "binding": {
        "name": "businessCalendar_optional",
        "type": "zeebe:input"
      },
      "type": "Dropdown",
      "choices": [
        {
          "name": "Yes",
          "value": "true"
        },
        {
          "name": "No",
          "value": "false"
        }
      ],
      "group": "Input"
    },
    {
      "condition": {
        "property": "businessCalendar_optional",
        "equals": "true"
      },
      "id": "businessCalendar",
      "label": "Business Calendar",
      "description": "List of business calendar slot. Default is Monday to Friday, 09:00 to 18:00",
      "type": "String",
      "feel": "optional",
      "binding": {
        "name": "businessCalendar",
        "type": "zeebe:input"
      },
      "group": "Input"
    },
    {
      "condition": {
        "property": "calendarAdvanceFunction",
        "oneOf": [
          "advance-hours"
        ]
      },
      "id": "useHolidays",
      "label": "Use holidays",
      "description": "Holidays on country is used and considered as closed",
      "type": "Dropdown",
      "choices": [
        {
          "name": "Yes",
          "value": "true"
        },
        {
          "name": "No",
          "value": "false"
        }
      ],
      "binding": {
        "name": "useHolidays",
        "type": "zeebe:input"
      },
      "constraints": {
        "notEmpty": true
      },
      "group": "Input"
    },
    {
      "condition": {
        "property": "useHolidays",
        "oneOf": [
          "true"
        ]
      },
      "id": "holidaysCountries",
      "label": "Holiday countries",
      "description": "List of countries separate by semi column (FR;USA°) ",
      "type": "String",
      "feel": "optional",
      "binding": {
        "name": "holidaysCountries",
        "type": "zeebe:input"
      },
      "constraints": {
        "notEmpty": true
      },
      "group": "Input"
    },
    {
      "id": "foundDate",
      "label": "Found Date",
      "description": "Return if a date is found by the calculation",
      "type": "String",
      "feel": "optional",
      "binding": {
        "source": "\u003d result.foundDate",
        "type": "zeebe:output"
      },
      "constraints": {
        "notEmpty": true
      },
      "group": "Output"
    },
    {
      "condition": {
        "property": "calendarAdvanceFunction",
        "oneOf": [
          "advance-hours"
        ]
      },
      "id": "resultDate",
      "label": "Result Date",
      "description": "Date, LocalDateTime format, returned",
      "type": "String",
      "feel": "optional",
      "binding": {
        "source": "\u003d result.resultDate",
        "type": "zeebe:output"
      },
      "constraints": {
        "notEmpty": true
      },
      "group": "Output"
    },
    {
      "label": "ControllerPage Expression",
      "description": "Expression to define BPMN Errors to throw",
      "type": "Hidden",
      "value": "if is defined(error) then bpmnError(error.code, error.message) else null",
      "binding": {
        "key": "errorExpression",
        "type": "zeebe:taskHeader"
      }
    }
  ]
}