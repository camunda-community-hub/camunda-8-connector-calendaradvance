    <bpmn:serviceTask id="Activity_1tww7bn" name="T2. Reverse date + Holiday : 12h10mn" zeebe:modelerTemplate="io.camunda.connector.calendaradvance.CalendarAdvanceFunction" zeebe:modelerTemplateIcon="data:image/png;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="c-calendaradvance-function" />
        <zeebe:ioMapping>
          <zeebe:input source="advance-hours" target="calendarAdvanceFunction" />
          <zeebe:input source="2026-07-15T10:34:00" target="startDate" />
          <zeebe:input source="PT12H10M" target="duration" />
          <zeebe:input source="backward" target="direction" />
          <zeebe:input source="false" target="businessCalendar_optional" />
          <zeebe:input source="true" target="useHolidays" />
          <zeebe:input source="=[&#34;FR&#34;]" target="holidaysCountries" />
          <zeebe:input target="businessTimeZone" />
          <zeebe:input source="true" target="foundDate_optional" />
          <zeebe:input source="true" target="resultDate_optional" />
          <zeebe:input source="false" target="listPeriods_optional" />
          <zeebe:input source="false" target="resultZonedDate_optional" />
          <zeebe:output source="= result.foundDate" target="BackHolidayJuly10.found" />
          <zeebe:output source="= result.resultDate" target="BackHolidayJuly10.resultDate" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="resultVariable" value="result" />
          <zeebe:header key="errorExpression" value="if is defined(error) then bpmnError(error.code, error.message) else null" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1b50esx</bpmn:incoming>
      <bpmn:outgoing>Flow_1732h4j</bpmn:outgoing>
    </bpmn:serviceTask>
